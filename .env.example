# =============================================================================
# GPT Speech Realtime Data — environment template
#
# Setup:
#   cp .env.example .env
#   Fill in the blank values below.
#
# With `pnpm dev`, a single root `.env` is enough for React (REACT_APP_*)
# and the Express server. Copy the same file to `server/.env` only if you
# run the server from the server/ directory directly.
# =============================================================================

# --- Server ---
PORT=3001
NODE_ENV=development

# --- OpenAI (required: chat, vision analysis, image generation) ---
# Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Legacy alias still supported in code: openAPIKey=

# Optional model overrides (defaults used if unset)
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=gpt-image-1
DEFAULT_PERSONALITY=default

# --- Multi-provider (beta): enable by adding keys; catalog filters to configured providers ---
# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# xAI / Grok — https://console.x.ai/
XAI_API_KEY=

# Groq (open-weight models) — https://console.groq.com/
GROQ_API_KEY=

# --- Frontend ↔ backend shared secret (required for /file save & export) ---
# Must be the same value in both variables.
theCode=
REACT_APP_API_KEY=

# --- Web search (get_realtime_data) — toggle in Settings panel or via SEARCH_PROVIDER=brave|perplexity ---
# Brave (recommended, Bing-style raw results): https://api-dashboard.search.brave.com/
BRAVE_API_KEY=
SEARCH_PROVIDER=brave

# Perplexity (AI-pre-summarized search): https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=
PPLX_MODEL=sonar-pro

# --- Optional tool APIs (only needed if the model calls these functions) ---

# OpenWeatherMap — get_current_weather
# https://openweathermap.org/api
weatherAPIKey=

# NewsData.io — get_news (aliases: NEWS_API_KEY, NEWSDATA_API_KEY)
# https://newsdata.io/
newsAPIKey=
NEWS_API_KEY=
NEWSDATA_API_KEY=

# RapidAPI Streaming Availability — get_shows
# https://rapidapi.com/movie-of-the-night-movie-of-the-night-default/api/streaming-availability
showsAPIKey=

# --- React app: optional numeric password gate on first load ---
REACT_APP_PASSWORD=
REACT_APP_STORAGE_KEY=
REACT_APP_MAX_LOGIN_ATTEMPTS=3
REACT_APP_LOCKOUT_TIME=1800000
REACT_APP_NODE_ENV=development

# --- Production: set when the API is not on the same origin as the React app ---
# REACT_APP_API_BASE_URL=https://your-api.example.com
